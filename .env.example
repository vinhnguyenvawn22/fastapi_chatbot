# =========================
# GEMINI CONFIG
# =========================
# Không ghi API key thật vào file này.
# Khi chạy thật, hãy copy file này thành .env rồi điền key thật.
GEMINI_API_KEY=your_gemini_api_key_here

# Model Gemini sử dụng cho chatbot
GEMINI_MODEL=gemini-2.5-flash


# =========================
# VECTOR DATABASE CONFIG
# =========================
# Đường dẫn lưu ChromaDB/vector store
VECTOR_STORE_PATH=storage/chroma_db

# Số lượng chunk lấy ra khi truy vấn tài liệu
RETRIEVAL_TOP_K=5

# Ngưỡng điểm tương đồng tối thiểu
SIMILARITY_THRESHOLD=0.3


# =========================
# APP CONFIG
# =========================
APP_NAME=FastAPI Chatbot
APP_ENV=development